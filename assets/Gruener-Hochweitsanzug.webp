<script>
document.addEventListener('DOMContentLoaded', function() {
  const cookieMenuItem = document.querySelector('.cookie-settings-trigger');

  if (cookieMenuItem) {
    cookieMenuItem.addEventListener('click', function(event) {
      event.preventDefault();
      if (typeof window.openCookieDialog === 'function') {
        window.openCookieDialog();
      } else {
        console.error('The function "openCookieDialog" was not found or is not a function.');
      }
    });
  }
});
</script>
